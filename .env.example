# Copy this file to .env. Sign-in is done by hand in a browser window
# (run `python -m deepseek.auth`), so no credentials are stored here.

# --- Optional ---
# DEEPSEEK_PROFILE_DIR=session/profile   # reuse an existing signed-in Chrome profile
# HOST=127.0.0.1
# PORT=8000
# RATE_LIMIT_PER_MINUTE=30               # per-client-IP limit on /v1 endpoints
